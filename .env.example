# FleetFinder configuration — copy to .env and edit

# Bind address. 0.0.0.0 makes the server reachable from phones on the LAN
# (needed for QR-code scanning). 127.0.0.1 keeps it on this Mac only.
HOST=0.0.0.0
PORT=12792

# Shared PIN required to use vehicle pages from devices on the LAN.
# Requests from this Mac (localhost) skip the PIN. Leave blank to disable.
FLEET_PIN=0000

# Webapp sync target (set when the cloud webapp is ready)
# SYNC_URL=https://your-webapp.example.com/api/fleet/sync
# SYNC_TOKEN=
